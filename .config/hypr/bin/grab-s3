#!/bin/bash

PROFILE_NAME="vic-prod"
BUCKET_NAME="veridos-cloudfactory.file.prod/updates"

usage() {
  echo "Usage: $0 <key1> [<key2> ... <keyN>]"
  exit 1
}

log() {
  local MESSAGE="$1"
  echo "$(date +"%Y-%m-%d %H:%M:%S") : $MESSAGE"
}

error_exit() {
  local MESSAGE="$1"
  log "ERROR: $MESSAGE"
  exit 1
}

# Main script
main() {
  local KEYS=("$@")

  # Validate inputs
  if [[ ${#KEYS[@]} -eq 0 ]]; then
    usage
  fi

  # Loop through each provided key and download it from the bucket
  for KEY in "${KEYS[@]}"; do
    if [[ -n "$KEY" ]]; then
      log "Downloading $KEY from s3://$BUCKET_NAME/$KEY using profile $PROFILE_NAME"
      if ! aws --profile "$PROFILE_NAME" s3 cp "s3://$BUCKET_NAME/$KEY" .; then
        log "Failed to download $KEY"
      else
        log "Successfully downloaded $KEY"
      fi
    fi
  done
}

main "$@"
