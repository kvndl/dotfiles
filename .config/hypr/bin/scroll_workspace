#!/bin/bash

# Get the name of the currently focused monitor
focused_monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused).name')

# Get a sorted list of workspace IDs assigned to the currently focused monitor
workspaces_on_monitor=$(hyprctl workspaces -j | jq -r --arg monitor "$focused_monitor" '.[] | select(.monitor == $monitor) | .id' | sort -n)

# Get the current active workspace ID on the focused monitor
current_workspace=$(hyprctl monitors -j | jq -r '.[] | select(.focused).activeWorkspace.id')

# Convert the workspace list to an array
workspace_array=($workspaces_on_monitor)

# Find the index of the current workspace in the array
for i in "${!workspace_array[@]}"; do
    if [[ "${workspace_array[$i]}" == "$current_workspace" ]]; then
        current_index=$i
        break
    fi
done

# Determine the next workspace index based on direction
if [ "$1" == "up" ]; then
    next_index=$(( (current_index + 1) % ${#workspace_array[@]} ))  # Loop back to the start
elif [ "$1" == "down" ]; then
    next_index=$(( (current_index - 1 + ${#workspace_array[@]}) % ${#workspace_array[@]} ))  # Loop back to the end
else
    echo "Usage: $0 {up|down}"
    exit 1
fi

# Get the next workspace ID
next_workspace="${workspace_array[$next_index]}"

# Switch to the calculated workspace
hyprctl dispatch workspace "$next_workspace"
