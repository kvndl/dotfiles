#!/usr/bin/env bash

# Directory to store wallpapers
WALLPAPER_DIR="$HOME/Pictures/Bing"

# Ensure the directory exists
mkdir -p "$WALLPAPER_DIR"

# Fetch the relative URL of the latest Bing wallpaper
IMAGE_URL_REL=$(curl -s "https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=1" | jq -r '.images[0].url')

# Check if the URL was retrieved successfully
if [ -z "$IMAGE_URL_REL" ]; then
    echo "Failed to retrieve wallpaper URL."
    exit 1
fi

# Construct the full image URL
IMAGE_URL="https://www.bing.com$IMAGE_URL_REL"

# Extract the image filename
IMAGE_NAME=$(basename "$IMAGE_URL")

# Full path to the downloaded image
IMAGE_PATH="$WALLPAPER_DIR/$IMAGE_NAME"

# Download the image if it doesn't already exist
if [ ! -f "$IMAGE_PATH" ]; then
    curl -s -o "$IMAGE_PATH" "$IMAGE_URL"
    if [ $? -ne 0 ]; then
        echo "Failed to download the wallpaper."
        exit 1
    fi
fi

# Set the wallpaper using swww
swww img "$IMAGE_PATH"
