# ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
# ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
# ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
# ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
# ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ
# =============================================================================
#          Dynamic Wallpaper Changer with Shuffled and Bing Modes          
# =============================================================================
# Author: Your Name
# Version: 2.2
# Date: 2024-04-28
# Description: 
# This script manages desktop wallpapers by periodically changing them every 5 
# minutes. It supports two modes: shuffled wallpapers from pre-configured 
# sources and Bing daily wallpapers. The script is designed to run continuously 
# as a systemd service.
# =============================================================================

# =============================== #
#        Set Daily Wallpaper      #
# =============================== #

# Configuration Variables
WALLPAPER_DIR="$HOME/Pictures/Wallpapers"
SHUFFLED_DIR="$WALLPAPER_DIR/Shuffled"
BING_DIR="$WALLPAPER_DIR/Bing"
CACHE_LIMIT=1000       # Maximum number of shuffled wallpapers to keep
CHANGE_INTERVAL=300    # 5 minutes in seconds
PID_FILE="$HOME/.set-daily-wall.pid"
MODE_FILE="$HOME/.set-daily-wall.mode"
LIST_FILE="$WALLPAPER_DIR/shuffled_list.txt"

# Pre-configured wallpaper sources
PRECONFIGURED_SOURCES=(
    "https://wallhaven.cc/search?q=dark+nature&categories=111&purity=100&sorting=random&order=desc"
    "https://unsplash.com/s/photos/dark-textures"
    "https://www.pexels.com/search/dark%20nature/"
)

# Dependencies
DEPENDENCIES=(curl jq swww grep sed awk)

# Ensure necessary directories exist
mkdir -p "$SHUFFLED_DIR" "$BING_DIR"

# Function to check dependencies
check_dependencies() {
    local missing=()
    for cmd in "${DEPENDENCIES[@]}"; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done

    if [ ${#missing[@]} -ne 0 ]; then
        echo "Missing dependencies: ${missing[*]}"
        echo "Please install the missing dependencies and rerun the script."
        exit 1
    fi
}

# Function to download Bing daily wallpaper
download_bing_wallpaper() {
    local today
    today=$(date +%Y-%m-%d)
    local wallpaper_path="$BING_DIR/$today.jpg"

    # If today's wallpaper is already downloaded, skip
    if [ -f "$wallpaper_path" ]; then
        return
    fi

    # Fetch the daily wallpaper URL
    local wallpaper_url
    wallpaper_url=$(curl -s "https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=1" | jq -r '.images[0].url')

    # Check if the URL was fetched correctly
    if [ -z "$wallpaper_url" ] || [ "$wallpaper_url" == "null" ]; then
        echo "$(date): Failed to retrieve Bing wallpaper URL."
        return
    fi

    # Full URL
    local full_url="https://www.bing.com${wallpaper_url}"

    # Download the wallpaper
    curl -s -o "$wallpaper_path" "$full_url"

    if [ $? -eq 0 ] && [ -s "$wallpaper_path" ]; then
        echo "$(date): Downloaded Bing wallpaper for $today."
    else
        echo "$(date): Failed to download Bing wallpaper."
        rm -f "$wallpaper_path"
    fi
}

# Function to fetch and download shuffled wallpapers from sources
fetch_shuffled_wallpapers() {
    echo "$(date): Fetching shuffled wallpapers from configured sources..."

    for source in "${PRECONFIGURED_SOURCES[@]}"; do
        echo "$(date): Processing source: $source"

        case "$source" in
            *wallhaven.cc*)
                fetch_wallhaven_wallpapers "$source"
                ;;
            *unsplash.com*)
                fetch_unsplash_wallpapers "$source"
                ;;
            *pexels.com*)
                fetch_pexels_wallpapers "$source"
                ;;
            *)
                echo "$(date): No fetcher defined for source: $source"
                ;;
        esac
    done

    echo "$(date): Finished fetching shuffled wallpapers."
}

# Function to fetch wallpapers from Wallhaven
fetch_wallhaven_wallpapers() {
    local url="$1"
    echo "$(date): Fetching from Wallhaven: $url"

    # Fetch the HTML content
    local html
    html=$(curl -s "$url")

    # Extract image page URLs
    local image_pages
    image_pages=$(echo "$html" | grep -oP 'href="/w/\K[^"]+' | uniq | head -n 20) # Limit to 20 per source

    for path in $image_pages; do
        local img_page="https://wallhaven.cc/w/$path"

        # Fetch the image page
        local img_html
        img_html=$(curl -s "$img_page")

        # Extract the full image URL
        local full_img_url
        full_img_url=$(echo "$img_html" | grep -oP 'href="https://w\.wallhaven\.cc/full/\w+/wallhaven-\w+\.jpg"' | head -n1 | sed 's/href="//')

        if [ -n "$full_img_url" ]; then
            download_image "$full_img_url" "$SHUFFLED_DIR"
        fi
    done
}

# Function to fetch wallpapers from Unsplash
fetch_unsplash_wallpapers() {
    local url="$1"
    echo "$(date): Fetching from Unsplash: $url"

    # Fetch the HTML content
    local html
    html=$(curl -s "$url")

    # Extract image URLs from srcset
    local image_urls
    image_urls=$(echo "$html" | grep -oP 'srcset="\K[^"]+' | awk -F ', ' '{print $1}' | uniq | head -n 20)

    for img_url in $image_urls; do
        download_image "$img_url" "$SHUFFLED_DIR"
    done
}

# Function to fetch wallpapers from Pexels
fetch_pexels_wallpapers() {
    local url="$1"
    echo "$(date): Fetching from Pexels: $url"

    # Fetch the HTML content
    local html
    html=$(curl -s "$url")

    # Extract image URLs
    local image_urls
    image_urls=$(echo "$html" | grep -oP 'src="\K[^"]+' | grep -E 'https?://images\.pexels\.com/photos/.+\.jpg' | uniq | head -n 20)

    for img_url in $image_urls; do
        download_image "$img_url" "$SHUFFLED_DIR"
    done
}

# Generic function to download an image if it doesn't already exist
download_image() {
    local url="$1"
    local dest_dir="$2"

    # Extract filename
    local filename
    filename=$(basename "$url")

    # Define the path
    local path="$dest_dir/$filename"

    # Check if the image already exists
    if [ -f "$path" ]; then
        return
    fi

    # Download the image
    curl -s -o "$path" "$url"

    # Verify the download was successful
    if [ $? -eq 0 ] && [ -s "$path" ]; then
        echo "$(date): Downloaded $filename"
    else
        echo "$(date): Failed to download $url"
        rm -f "$path" # Remove incomplete file
    fi
}

# Function to set wallpaper using swww
set_wallpaper() {
    local wallpaper_path="$1"
    swww img "$wallpaper_path" --transition-type fade --transition-fps 60
}

# Function to shuffle shuffled wallpapers
shuffle_wallpapers() {
    echo "$(date): Shuffling wallpapers..."
    shuf -e "$SHUFFLED_DIR"/*.jpg > "$LIST_FILE"
}

# Function to change wallpaper in shuffled mode
change_shuffled_wallpaper() {
    if [ ! -f "$LIST_FILE" ] || [ ! -s "$LIST_FILE" ]; then
        echo "$(date): Shuffled list not found or empty. Shuffling wallpapers..."
        shuffle_wallpapers
    fi

    local wallpaper
    wallpaper=$(head -n 1 "$LIST_FILE")

    if [ ! -f "$wallpaper" ]; then
        echo "$(date): Wallpaper not found: $wallpaper. Removing from list."
        sed -i '1d' "$LIST_FILE"
        change_shuffled_wallpaper
        return
    fi

    set_wallpaper "$wallpaper"

    # Rotate the list
    sed -i '1d' "$LIST_FILE"

    # Optionally, fetch more wallpapers if running low
    local current_count
    current_count=$(wc -l < "$LIST_FILE")
    if [ "$current_count" -lt 50 ]; then
        echo "$(date): Shuffled wallpaper count low ($current_count). Fetching more wallpapers..."
        fetch_shuffled_wallpapers
        shuffle_wallpapers
    fi
}

# Function to change wallpaper in Bing mode
change_bing_wallpaper() {
    download_bing_wallpaper

    local today
    today=$(date +%Y-%m-%d)
    local wallpaper_path="$BING_DIR/$today.jpg"

    if [ -f "$wallpaper_path" ]; then
        set_wallpaper "$wallpaper_path"
    else
        echo "$(date): Bing wallpaper not available."
    fi
}

# Function to handle mode switching
current_mode=""
handle_mode_switch() {
    if [ ! -f "$MODE_FILE" ]; then
        current_mode="shuffled"
        echo "shuffled" > "$MODE_FILE"
    else
        current_mode=$(cat "$MODE_FILE")
    fi
}

# Function to advance to the next shuffled wallpaper
advance_wallpaper() {
    if [ "$current_mode" != "shuffled" ]; then
        echo "$(date): Cannot advance wallpaper. Current mode is '$current_mode'."
        return
    fi

    change_shuffled_wallpaper
    echo "$(date): Advanced to the next shuffled wallpaper."
}

# Function to switch modes
switch_mode() {
    if [ $# -lt 1 ]; then
        echo "Usage: $0 switch [shuffled|bing]"
        exit 1
    fi

    local new_mode="$1"

    if [ "$new_mode" != "shuffled" ] && [ "$new_mode" != "bing" ]; then
        echo "Invalid mode: $new_mode. Use 'shuffled' or 'bing'."
        exit 1
    fi

    echo "$new_mode" > "$MODE_FILE"
    echo "$(date): Mode switched to $new_mode."
}

# Function to display help
show_help() {
    echo "Usage: $0 [command]"
    echo
    echo "Commands:"
    echo "  start                   Start the wallpaper changer (managed via systemd)"
    echo "  switch [shuffled|bing]  Switch wallpaper mode"
    echo "  advance                 Advance to the next shuffled wallpaper"
    echo "  help                    Show this help message"
}

# Function to initialize the cache
init_cache() {
    echo "$(date): Initializing wallpaper cache..."
    fetch_shuffled_wallpapers
    shuffle_wallpapers
    download_bing_wallpaper
    echo "$(date): Wallpaper cache initialized."
}

# Function to handle signals
handle_signals() {
    case "$1" in
        USR1)
            advance_wallpaper
            ;;
    esac
}

# Trap for signals
trap 'handle_signals USR1' USR1

# Function to ensure single instance
ensure_single_instance() {
    if [ -f "$PID_FILE" ]; then
        local existing_pid
        existing_pid=$(cat "$PID_FILE")
        if kill -0 "$existing_pid" 2>/dev/null; then
            echo "Wallpaper changer is already running with PID $existing_pid."
            exit 1
        else
            echo "Removing stale PID file."
            rm -f "$PID_FILE"
        fi
    fi
}

# Function to start the wallpaper changer
start_changer() {
    ensure_single_instance

    init_cache
    handle_mode_switch

    # Start the background loop
    (
        while true; do
            if [ "$current_mode" == "shuffled" ]; then
                change_shuffled_wallpaper
            elif [ "$current_mode" == "bing" ]; then
                change_bing_wallpaper
            else
                echo "$(date): Unknown mode: $current_mode"
            fi

            sleep "$CHANGE_INTERVAL"
        done
    ) &

    # Save the PID
    echo $! > "$PID_FILE"
    echo "Wallpaper changer started with PID $(cat "$PID_FILE")."
}

# Main script logic
check_dependencies

case "$1" in
    start)
        start_changer
        ;;
    switch)
        shift
        switch_mode "$@"
        ;;
    advance)
        if [ -f "$PID_FILE" ]; then
            local pid
            pid=$(cat "$PID_FILE")
            if kill -0 "$pid" 2>/dev/null; then
                kill -USR1 "$pid"
                echo "Advanced to the next shuffled wallpaper."
            else
                echo "Wallpaper changer is not running."
            fi
        else
            echo "Wallpaper changer is not running."
        fi
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        show_help
        ;;
esac
